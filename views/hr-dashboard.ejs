<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0,viewport-fit=cover"/>
  <title>HR Dashboard — IED HRMS</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --ink:#0f1923;--cream:#f5f0e8;--rust:#c94a2b;--gold:#d4a843;
      --green:#2d6a4f;--card:#fff;--border:#e0d9ce;--muted:#7a7166;
      --navy:#1e3a5f;--shadow:0 4px 24px rgba(0,0,0,.07);
    }
    body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);min-height:100vh}
    header{
      background:var(--ink);min-height:64px;padding:10px 28px;
      display:flex;align-items:center;justify-content:space-between;
      gap:12px;box-shadow:0 2px 16px rgba(0,0,0,.2);position:sticky;top:0;z-index:100;flex-wrap:wrap;
    }
    .h-left{display:flex;align-items:center;gap:14px;flex-wrap:wrap}
    .h-logo{width:38px;height:38px;object-fit:contain;border-radius:10px;background:rgba(255,255,255,.1);padding:3px}
    .h-brand{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#fff;letter-spacing:-.3px}
    .h-brand span{color:var(--gold)}
    .h-nav{display:flex;gap:4px;margin-left:12px;flex-wrap:wrap}
    .h-nav a{color:rgba(255,255,255,.65);text-decoration:none;font-size:13px;font-weight:500;padding:6px 14px;border-radius:8px;transition:all .2s}
    .h-nav a:hover,.h-nav a.active{background:rgba(255,255,255,.12);color:#fff}
    .h-right{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
    .h-user{font-size:12.5px;color:rgba(255,255,255,.7);background:rgba(255,255,255,.08);padding:5px 12px;border-radius:30px}
    .btn-out{padding:6px 14px;background:var(--rust);color:#fff;border:none;border-radius:8px;font-size:12.5px;font-weight:600;cursor:pointer;text-decoration:none;font-family:'DM Sans',sans-serif}
    main{max-width:1400px;margin:0 auto;padding:24px 20px}

    /* ── STAT CARDS ── */
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;margin-bottom:22px}
    .scard{background:var(--card);border-radius:16px;padding:20px 22px;box-shadow:var(--shadow);display:flex;align-items:center;gap:16px;border:1px solid var(--border);transition:transform .15s}
    .scard:hover{transform:translateY(-2px)}
    .sicon{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
    .snum{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;line-height:1;color:var(--ink)}
    .slabel{font-size:11.5px;color:var(--muted);font-weight:400;margin-top:3px}

    /* ── FILTER CARD ── */
    .fcard{background:var(--card);border-radius:16px;box-shadow:var(--shadow);border:1px solid var(--border);padding:20px 24px;margin-bottom:20px}
    .fhead{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--ink);margin-bottom:14px}
    .quick{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
    .qbtn{padding:5px 14px;background:var(--cream);border:1.5px solid var(--border);border-radius:30px;font-size:12px;font-weight:500;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
    .qbtn:hover{background:var(--ink);color:#fff;border-color:var(--ink)}
    .frow{display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end}
    .fg{display:flex;flex-direction:column;gap:4px}
    .fg label{font-size:10.5px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
    .fg input{padding:9px 13px;border:1.5px solid var(--border);border-radius:10px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none;min-width:150px;transition:border-color .2s;background:#fafaf8}
    .fg input:focus{border-color:var(--rust)}
    .btn-apply{padding:9px 20px;background:var(--rust);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .2s}
    .btn-apply:hover{background:#b03d22}
    .btn-reset{padding:9px 16px;background:var(--cream);color:var(--muted);border:1.5px solid var(--border);border-radius:10px;font-size:13px;font-weight:500;cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;transition:all .2s}
    .btn-reset:hover{background:#e8e2d8}

    /* ── TABLE CARD ── */
    .tcard{background:var(--card);border-radius:16px;box-shadow:var(--shadow);border:1px solid var(--border);overflow:hidden;margin-bottom:20px}
    .tbar{display:flex;justify-content:space-between;align-items:center;padding:18px 22px;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:12px}
    .tbar-left .ttitle{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--ink)}
    .tbar-left .tsub{font-size:11.5px;color:var(--muted);margin-top:2px}
    .tbar-right{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
    .btn-export{display:flex;align-items:center;gap:7px;padding:9px 18px;background:linear-gradient(135deg,#16a34a,#15803d);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;box-shadow:0 3px 12px rgba(22,163,74,.25);transition:all .2s}
    .btn-export:hover{opacity:.9;transform:translateY(-1px)}
    .tscroll{overflow-x:auto}

    /* ── SUMMARY TABLE (main big one like image) ── */
    .sum-table{width:100%;border-collapse:collapse;font-size:13px;min-width:600px}
    .sum-table thead tr{background:#3730a3}
    .sum-table thead th{
      padding:13px 18px;text-align:left;font-size:11px;font-weight:700;
      text-transform:uppercase;letter-spacing:.7px;color:#fff;white-space:nowrap;
    }
    .sum-table thead th:not(:first-child){text-align:center}
    .sum-table tbody tr{border-bottom:1px solid #f0f0f0;transition:background .12s;cursor:pointer}
    .sum-table tbody tr:hover{background:#f5f3ff}
    .sum-table tbody tr:last-child{border-bottom:none}
    .sum-table td{padding:14px 18px;vertical-align:middle}
    .sum-table td:not(:first-child){text-align:center;font-family:'Syne',sans-serif;font-weight:700;font-size:15px}
    .emp-link{color:#3730a3;font-weight:600;font-size:13.5px;text-decoration:none}
    .emp-link:hover{text-decoration:underline}
    .emp-sub{font-size:11px;color:var(--muted);margin-top:2px}
    .num-present{color:#16a34a}
    .num-absent{color:#dc2626}
    .num-total{color:#1e3a5f}
    .num-zero{color:#94a3b8}

    /* ── DETAIL TABLE ── */
    table.detail{width:100%;border-collapse:collapse;font-size:12.5px;min-width:900px}
    table.detail thead th{background:#fafaf8;padding:10px 13px;text-align:left;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);border-bottom:1px solid var(--border);white-space:nowrap}
    table.detail thead th.gi{background:#f0fdf4;color:#15803d}
    table.detail thead th.go{background:#eff6ff;color:#1d4ed8}
    table.detail tbody tr{border-bottom:1px solid #f5f0e8;transition:background .1s}
    table.detail tbody tr:hover{background:#fafaf8}
    table.detail tbody tr:last-child{border-bottom:none}
    table.detail td{padding:12px 13px;vertical-align:middle}
    .emp-id{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;background:var(--cream);color:var(--navy);padding:3px 8px;border-radius:6px}
    .emp-name{font-weight:500;font-size:13px;color:var(--ink)}
    .emp-email{font-size:11px;color:var(--muted)}
    .tval{font-weight:600;font-size:12.5px}
    .tv-in{color:#15803d}.tv-out{color:#1d4ed8}
    .loc{max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11.5px;color:var(--muted)}
    .map-a{color:#3b82f6;font-size:11px;text-decoration:none;font-weight:500}
    .map-a:hover{text-decoration:underline}
    .badge{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
    .b-full{background:#dcfce7;color:#15803d}
    .b-half{background:#fef9c3;color:#854d0e}
    .b-short{background:#fee2e2;color:#b91c1c}
    .b-pending{background:#e0e7ff;color:#4338ca}
    .b-none{background:var(--cream);color:var(--muted)}

    .empty{text-align:center;padding:60px;color:var(--muted)}
    .empty .ei{font-size:42px;margin-bottom:12px}
    .err-box{background:#fff0ee;color:#c94a2b;padding:12px 18px;border-radius:10px;margin-bottom:18px;font-size:13px;border-left:4px solid var(--rust)}
    .section-label{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px;padding-left:2px}

    @media(max-width:768px){
      main{padding:16px 12px}
      .stats{grid-template-columns:1fr 1fr;gap:10px}
      .snum{font-size:24px}
      .tbar{flex-direction:column;align-items:stretch}
      .btn-export{justify-content:center}
      .frow .fg input{min-width:120px}
      .h-nav{margin-left:0}
    }
  </style>
</head>
<body>
<header>
  <div class="h-left">
    <img src="/images/IED_LOGO.jpg" alt="IED" class="h-logo" onerror="this.style.display='none'"/>
    <div class="h-brand">IED <span>HRMS</span></div>
    <nav class="h-nav">
      <a href="/hr/dashboard" class="active">📊 Attendance</a>
      <a href="/hr/employees">👥 Employees</a>
    </nav>
  </div>
  <div class="h-right">
    <span class="h-user">👤 <%= hr.name %></span>
    <a href="/hr/logout" class="btn-out">Logout</a>
  </div>
</header>

<main>
  <% if(typeof dbError!=='undefined' && dbError){ %>
    <div class="err-box">⚠️ DB Error: <%= dbError %></div>
  <% } %>

  <!-- Stat Cards -->
  <div class="stats">
    <div class="scard">
      <div class="sicon" style="background:#f0fdf4">📋</div>
      <div><div class="snum"><%= summary.total_records %></div><div class="slabel">Total Records</div></div>
    </div>
    <div class="scard">
      <div class="sicon" style="background:#dcfce7">✅</div>
      <div><div class="snum"><%= summary.complete %></div><div class="slabel">Complete (IN+OUT)</div></div>
    </div>
    <div class="scard">
      <div class="sicon" style="background:#fef9c3">⏳</div>
      <div><div class="snum"><%= summary.pending_out %></div><div class="slabel">Pending OUT</div></div>
    </div>
    <div class="scard">
      <div class="sicon" style="background:#dbeafe">👥</div>
      <div><div class="snum"><%= summary.unique_employees %></div><div class="slabel">Unique Employees</div></div>
    </div>
  </div>

  <!-- Filters -->
  <div class="fcard">
    <div class="fhead">🔍 Filter Records</div>
    <div class="quick">
      <button class="qbtn" type="button" onclick="setToday()">Today</button>
      <button class="qbtn" type="button" onclick="setYesterday()">Yesterday</button>
      <button class="qbtn" type="button" onclick="setThisWeek()">This Week</button>
      <button class="qbtn" type="button" onclick="setThisMonth()">This Month</button>
      <button class="qbtn" type="button" onclick="setLastMonth()">Last Month</button>
    </div>
    <form method="GET" action="/hr/dashboard" id="filterForm">
      <div class="frow">
        <div class="fg"><label>From Date</label><input type="date" name="date_from" id="d1" value="<%= filters.date_from %>" onchange="submitForm()"/></div>
        <div class="fg"><label>To Date</label><input type="date" name="date_to" id="d2" value="<%= filters.date_to %>" onchange="submitForm()"/></div>
        <div class="fg"><label>Emp ID</label><input type="text" name="emp_id" placeholder="IED_01…" value="<%= filters.emp_id %>" onchange="submitForm()"/></div>
        <div class="fg"><label>Email</label><input type="text" name="emp_email" placeholder="Search email…" value="<%= filters.emp_email %>" onchange="submitForm()"/></div>
        <a href="/hr/dashboard" class="btn-reset">Reset</a>
      </div>
    </form>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       ATTENDANCE REPORT (clean & simplified layout)
       ═══════════════════════════════════════════════════════ -->
  <% if(typeof employeeSummary !== 'undefined' && employeeSummary && employeeSummary.length > 0){ %>
  <div class="section-label">Attendance Report
    <% if(typeof reportRange !== 'undefined' && reportRange){ %>
      — <%= reportRange.startKey %> to <%= reportRange.endKey %>
    <% } %>
  </div>
  <div class="tcard">
    <div class="tbar">
      <div class="tbar-left">
        <div class="ttitle">All Employees — Attendance Report</div>
        <div class="tsub"><%= employeeSummary.length %> employee(s)
          <% if(typeof reportRange !== 'undefined' && reportRange){ %> · <%= reportRange.totalDays %> working days in period<% } %>
        </div>
      </div>
      <div class="tbar-right">
        <a href="/hr/export?date_from=<%= filters.date_from %>&date_to=<%= filters.date_to %>&emp_email=<%= filters.emp_email %>&emp_id=<%= filters.emp_id %>" class="btn-export">
          📥 Export Excel
        </a>
      </div>
    </div>
    <div class="tscroll">
      <table class="sum-table">
        <thead>
          <tr>
            <th>#&nbsp;&nbsp;Employee Name</th>
            <th style="text-align:center">Employee ID</th>
            <th style="text-align:center">Total Days</th>
            <th style="text-align:center">Present</th>
            <th style="text-align:center">Absent</th>
          </tr>
        </thead>
        <tbody>
          <% employeeSummary.forEach((row, idx) => {
            const isAbsent0 = row.absent === 0;
            const isPresent0 = row.present === 0;
          %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:10px">
                <div style="width:36px;height:36px;border-radius:10px;background:#3730a3;display:flex;align-items:center;justify-content:center;color:#fff;font-family:'Syne',sans-serif;font-weight:800;font-size:15px;flex-shrink:0">
                  <%= (row.emp_name||'?')[0].toUpperCase() %>
                </div>
                <div>
                  <div style="font-weight:600;font-size:13.5px;color:var(--ink)"><%= row.emp_name %></div>
                  <div class="emp-sub"><%= row.email %></div>
                </div>
              </div>
            </td>
            <td style="text-align:center"><span class="emp-id-badge" style="font-family:'Syne',sans-serif;font-size:11.5px;font-weight:700;background:var(--cream);color:var(--navy);padding:4px 10px;border-radius:8px;white-space:nowrap"><%= row.emp_id %></span></td>
            <td style="text-align:center"><span class="num-total"><%= row.total_days %></span></td>
            <td style="text-align:center"><span class="<%= isPresent0 ? 'num-zero' : 'num-present' %>"><%= row.present %></span></td>
            <td style="text-align:center"><span class="<%= isAbsent0 ? 'num-zero' : 'num-absent' %>"><%= row.absent %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
</main>

<script>
  const d1=document.getElementById('d1'), d2=document.getElementById('d2');
  const submitForm = () => document.getElementById('filterForm').submit();
  const fmt=d=>{
    const p=new Intl.DateTimeFormat('en-GB',{timeZone:'Asia/Kolkata',year:'numeric',month:'2-digit',day:'2-digit'}).formatToParts(d);
    const m={};p.forEach(x=>{if(x.type!=='literal')m[x.type]=x.value;});
    return `${m.year}-${m.month}-${m.day}`;
  };
  function setToday(){const t=new Date();d1.value=d2.value=fmt(t); submitForm();}
  function setYesterday(){const t=new Date();t.setDate(t.getDate()-1);d1.value=d2.value=fmt(t); submitForm();}
  function setThisWeek(){const t=new Date(),dy=t.getDay(),s=new Date(t);s.setDate(t.getDate()-(dy===0?6:dy-1));d1.value=fmt(s);d2.value=fmt(t); submitForm();}
  function setThisMonth(){const t=new Date();d1.value=fmt(new Date(t.getFullYear(),t.getMonth(),1));d2.value=fmt(t); submitForm();}
  function setLastMonth(){const t=new Date();d1.value=fmt(new Date(t.getFullYear(),t.getMonth()-1,1));d2.value=fmt(new Date(t.getFullYear(),t.getMonth(),0)); submitForm();}
</script>
</body>
</html>