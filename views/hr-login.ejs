<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>HR Login — IED HRMS</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --ink:#0f1923;--cream:#f5f0e8;--rust:#c94a2b;--gold:#d4a843;
      --card:#ffffff;--border:#e0d9ce;--muted:#7a7166;
    }
    body{
      font-family:'DM Sans',sans-serif;background:var(--cream);
      min-height:100vh;display:flex;align-items:center;justify-content:center;
      background-image:
        radial-gradient(ellipse at 20% 50%, rgba(201,74,43,0.06) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 20%, rgba(212,168,67,0.08) 0%, transparent 50%);
    }
    .wrap{width:100%;max-width:420px;padding:20px}
    .logo-area{text-align:center;margin-bottom:36px}
    .logo-img{width:60px;height:60px;object-fit:contain;border-radius:16px;
              box-shadow:0 4px 20px rgba(0,0,0,.12);margin-bottom:14px;display:inline-block}
    .brand{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;
           color:var(--ink);letter-spacing:-.5px}
    .brand span{color:var(--rust)}
    .sub{font-size:13px;color:var(--muted);margin-top:4px;font-weight:300}
    .card{background:var(--card);border-radius:20px;padding:36px;
          box-shadow:0 8px 40px rgba(0,0,0,.08),0 2px 8px rgba(0,0,0,.04);
          border:1px solid var(--border)}
    .card-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;
                color:var(--ink);margin-bottom:24px;text-align:center}
    .field{margin-bottom:18px}
    .field label{display:block;font-size:11.5px;font-weight:500;
                 color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px}
    .field input{
      width:100%;padding:13px 16px;border:1.5px solid var(--border);border-radius:12px;
      font-size:14px;font-family:'DM Sans',sans-serif;color:var(--ink);
      background:#fafaf8;outline:none;transition:border-color .2s,box-shadow .2s
    }
    .field input:focus{border-color:var(--rust);box-shadow:0 0 0 3px rgba(201,74,43,.1)}
    .btn{
      width:100%;padding:14px;background:var(--rust);color:#fff;border:none;
      border-radius:12px;font-size:15px;font-weight:600;font-family:'Syne',sans-serif;
      cursor:pointer;letter-spacing:.2px;transition:all .2s;margin-top:4px
    }
    .btn:hover{background:#b03d22;transform:translateY(-1px);box-shadow:0 6px 20px rgba(201,74,43,.3)}
    .btn:active{transform:translateY(0)}
    .error{background:#fff0ee;border:1px solid #f5c0b5;color:#c94a2b;
           padding:12px 16px;border-radius:10px;font-size:13px;margin-bottom:18px;text-align:center}
    .footer-link{text-align:center;margin-top:20px;font-size:12.5px;color:var(--muted)}
    .footer-link a{color:var(--rust);text-decoration:none;font-weight:500}
    .emp-link{
      display:block;text-align:center;margin-top:16px;padding:12px;
      background:var(--cream);border:1.5px solid var(--border);border-radius:12px;
      font-size:13px;color:var(--ink);text-decoration:none;font-weight:500;transition:all .2s
    }
    .emp-link:hover{border-color:var(--gold);background:#fff}
  </style>
</head>
<body>
<div class="wrap">
  <div class="logo-area">
    <img src="/images/IED_LOGO.jpg" alt="IED" class="logo-img" onerror="this.style.display='none'"/>
    <div class="brand">IED <span>HRMS</span></div>
    <div class="sub">Human Resource Management System</div>
  </div>
  <div class="card">
    <div class="card-title">HR Admin Login</div>
    <% if(error){ %><div class="error">⚠️ <%= error %></div><% } %>
    <form method="POST" action="/hr/login">
      <div class="field">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="hr@company.com" required autocomplete="username"/>
      </div>
      <div class="field">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" required autocomplete="current-password"/>
      </div>
      <button type="submit" class="btn">Login to Dashboard →</button>
    </form>
  </div>
  <a href="/emp/login" class="emp-link">👤 Employee? Login with your EMP ID & PIN</a>
</div>
</body>
</html>
