<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>IED Attendance System</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="<%= (typeof initialUser !== 'undefined' && initialUser) ? '' : 'auth-only' %>">

  <div class="wrapper">
    <!-- Header -->
    <header>
      <div class="logo">
        <img src="/images/IED_LOGO.jpg" alt="IED" class="site-logo" onerror="this.style.display='none'" />
        <span class="logo-text">IED Attendance</span>
      </div>
      <div class="header-actions">
        <div class="header-email" id="headerEmail">Sign in with Google</div>
        <a href="/auth/google" class="auth-btn auth-btn-primary" id="authBtn">Google Sign-In</a>
        <a href="/logout" class="auth-btn auth-btn-ghost" id="logoutBtn" style="display:none">Logout</a>
      </div>
    </header>

    <!-- Main Card -->
    <main>
      <div class="card" id="mainCard">

        <div class="auth-panel" id="authPrompt">
          <div>
            <div class="auth-title">Sign in with Google to continue</div>
            <div class="auth-sub">Manual email entry has been removed. Punch IN and Punch OUT will use your Google account automatically.</div>
          </div>
          <a href="/auth/google" class="auth-btn auth-btn-primary">Continue with Google</a>
        </div>

        <!-- Status Banner -->
        <div class="status-banner" id="statusBanner">
          <div class="pulse-dot"></div>
          <span id="statusText">Fetching your location...</span>
        </div>

        <!-- Employee Info -->
        <div class="emp-info">
          <div class="avatar" id="avatarInitial">?</div>
          <div class="emp-details">
            <div class="emp-email" id="empEmail">Loading account...</div>
            <div class="emp-date" id="empDate">—</div>
          </div>
        </div>

        <!-- Location Info -->
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">📍 Location</span>
            <span class="info-value" id="locationName">Fetching...</span>
          </div>
          <div class="info-item">
            <span class="info-label">🕐 Time</span>
            <span class="info-value" id="currentTime">—</span>
          </div>
          <div class="info-item">
            <span class="info-label">🌐 Coordinates</span>
            <span class="info-value" id="coordsDisplay">—</span>
          </div>
        </div>

        <!-- Divider -->
        <hr class="divider" />

        <!-- Today's Record -->
        <div class="today-record" id="todayRecord" style="display:none">
          <div class="record-title">Today's Record</div>
          <div class="record-row">
            <span class="record-item in" id="recordIn">
              <span class="rec-label">IN</span>
              <span class="rec-time" id="inTime">—</span>
            </span>
            <span class="record-arrow">→</span>
            <span class="record-item out" id="recordOut">
              <span class="rec-label">OUT</span>
              <span class="rec-time" id="outTime">—</span>
            </span>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="btn-group">
          <button class="btn btn-in" id="btnIn" onclick="punch('Punch In')" disabled>
            <span class="btn-icon">🟢</span>
            Punch IN
          </button>
          <button class="btn btn-out" id="btnOut" onclick="punch('Punch Out')" disabled>
            <span class="btn-icon">🔴</span>
            Punch OUT
          </button>
        </div>

        <!-- Error / Info Message -->
        <div class="msg" id="msgBox" style="display:none"></div>

      </div>

      <!-- Download Link -->
      <div class="download-row" style="display:flex;justify-content:center;gap:20px;flex-wrap:wrap">
        <!-- <a href="/hr/login" class="download-link">🏢 HR Portal</a> -->
      </div>
    </main>

    <!-- Toast -->
    <div class="toast" id="toast"></div>
  </div>

    <script type="application/json" id="initialSessionUser"><%- JSON.stringify(typeof initialUser !== 'undefined' ? initialUser : null) %></script>
  <script>
    // ─── STATE ────────────────────────────────────────────────────────────────
      const initialSessionUser = JSON.parse(document.getElementById('initialSessionUser').textContent || 'null');
    let userEmail = '';
    let currentUser = null;
    let userLat = null;
    let userLng = null;
    let locationName = '';
    let sessionLog = JSON.parse(sessionStorage.getItem('attendanceLog') || '{}');
    let attendanceState = { canPunchIn: false, canPunchOut: false, inTimeLabel: null, outTimeLabel: null };
    let locationReady = false;

    // ─── INIT ─────────────────────────────────────────────────────────────────
    window.addEventListener('DOMContentLoaded', async () => {
      updateClock();
      setInterval(updateClock, 1000);
      await loadSession();
    });

    async function loadSession() {
      try {
        if (initialSessionUser && initialSessionUser.email) {
          currentUser = initialSessionUser;
          setUser(initialSessionUser);
          showAuthenticatedUI();
          await refreshAttendanceState();
          startLocation();
          return;
        }

        const response = await fetch('/api/session', { credentials: 'same-origin' });
        const data = await response.json();

        if (data.authenticated && data.user && data.user.email) {
          currentUser = data.user;
          setUser(data.user);
          showAuthenticatedUI();
          await refreshAttendanceState();
          startLocation();
          return;
        }

        showUnauthenticatedUI();
      } catch (error) {
        showUnauthenticatedUI();
      }
    }

    function showAuthenticatedUI() {
      document.body.classList.remove('auth-only');
      document.getElementById('authPrompt').style.display = 'none';
      document.getElementById('authBtn').style.display = 'none';
      document.getElementById('logoutBtn').style.display = 'inline-flex';
      document.getElementById('headerEmail').textContent = currentUser.name || currentUser.email;
    }

    function showUnauthenticatedUI() {
      document.body.classList.add('auth-only');
      document.getElementById('authPrompt').style.display = 'flex';
      document.getElementById('authBtn').style.display = 'inline-flex';
      document.getElementById('logoutBtn').style.display = 'none';
      document.getElementById('headerEmail').textContent = 'Sign in with Google';
      setStatus('Sign in with Google to mark attendance', 'loading');
      updateButtonState(null, null);
    }

    function setUser(user) {
      userEmail = user.email.toLowerCase();
      document.getElementById('empEmail').textContent = user.name ? `${user.name} (${user.email})` : user.email;
      document.getElementById('headerEmail').textContent = user.name || user.email;
      const initialSource = user.name || user.email || '?';
      document.getElementById('avatarInitial').textContent = initialSource[0].toUpperCase();
    }

    async function refreshAttendanceState() {
      if (!userEmail) return;
      try {
        const response = await fetch('/api/attendance/today', { credentials: 'same-origin' });
        const data = await response.json();

        if (!response.ok || !data.authenticated) {
          throw new Error(data.message || 'Unable to load attendance state');
        }

        attendanceState = {
          canPunchIn: !!data.canPunchIn,
          canPunchOut: !!data.canPunchOut,
          inTimeLabel: data.inTimeLabel || null,
          outTimeLabel: data.outTimeLabel || null
        };

        if (!sessionLog[userEmail]) {
          sessionLog[userEmail] = { date: new Date().toDateString(), inTime: null, outTime: null };
        }

        sessionLog[userEmail].date = new Date().toDateString();
        sessionLog[userEmail].inTime = data.inTimeLabel || null;
        sessionLog[userEmail].outTime = data.outTimeLabel || null;
        sessionStorage.setItem('attendanceLog', JSON.stringify(sessionLog));

        if (data.record) {
          document.getElementById('todayRecord').style.display = 'block';
          if (data.inTimeLabel) {
            document.getElementById('inTime').textContent = data.inTimeLabel;
          }
          if (data.outTimeLabel) {
            document.getElementById('outTime').textContent = data.outTimeLabel;
          }
        }

        syncButtonState();
      } catch (error) {
        attendanceState = { canPunchIn: false, canPunchOut: false, inTimeLabel: null, outTimeLabel: null };
        syncButtonState();
      }
    }

    // ─── LOCATION ─────────────────────────────────────────────────────────────
    function startLocation() {
      setStatus('Fetching location...', 'loading');
      if (!navigator.geolocation) {
        setStatus('Geolocation not supported', 'error');
        return;
      }
      navigator.geolocation.getCurrentPosition(onLocationSuccess, onLocationError, {
        enableHighAccuracy: true,
        timeout: 10000
      });
    }

    function onLocationSuccess(pos) {
      userLat = pos.coords.latitude.toFixed(6);
      userLng = pos.coords.longitude.toFixed(6);
      document.getElementById('coordsDisplay').textContent = `${userLat}, ${userLng}`;
      setStatus('Location found ✓', 'success');
      reverseGeocode(userLat, userLng);
      locationReady = true;
      syncButtonState();
    }

    function onLocationError(err) {
      setStatus('Location access denied — please allow location', 'error');
      locationName = 'Unknown';
      document.getElementById('locationName').textContent = 'Location not available';
      locationReady = true;
      syncButtonState(); // still allow punch with unknown location
    }

    function reverseGeocode(lat, lng) {
      fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=15&accept-language=en`)
        .then(r => r.json())
        .then(data => {
          const addr = data.address;
          locationName = addr.suburb || addr.neighbourhood || addr.village ||
                         addr.town || addr.city || addr.county || 'Unknown';
          document.getElementById('locationName').textContent = locationName;
        })
        .catch(() => {
          locationName = `${lat}, ${lng}`;
          document.getElementById('locationName').textContent = locationName;
        });
    }

    // ─── CLOCK ────────────────────────────────────────────────────────────────
    function updateClock() {
      const now = new Date();
      document.getElementById('currentTime').textContent = now.toLocaleTimeString('en-IN');
      document.getElementById('empDate').textContent = now.toLocaleDateString('en-IN', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
      });
    }

    // ─── BUTTONS ──────────────────────────────────────────────────────────────
    function syncButtonState() {
      const btnIn = document.getElementById('btnIn');
      const btnOut = document.getElementById('btnOut');
      const allowInteraction = locationReady || (!attendanceState.canPunchIn && !attendanceState.canPunchOut);
      btnIn.disabled = !allowInteraction || !attendanceState.canPunchIn;
      btnOut.disabled = !allowInteraction || !attendanceState.canPunchOut;
      btnIn.classList.toggle('done', !!attendanceState.inTimeLabel);
      btnOut.classList.toggle('done', !!attendanceState.outTimeLabel);
    }

    // ─── PUNCH ────────────────────────────────────────────────────────────────
    async function punch(status) {
      if (!currentUser || !userEmail) return showMsg('Please sign in with Google first', 'error');
      if (!userLat) {
        showMsg('Location not yet available. Please wait...', 'error');
        startLocation();
        return;
      } 

      const now = new Date();
      const timestamp = now.toISOString();
      const timeStr = now.toLocaleTimeString('en-IN');

      // Optimistic UI update
      const btnId = status === 'Punch In' ? 'btnIn' : 'btnOut';
      const btn = document.getElementById(btnId);
      btn.disabled = true;
      btn.textContent = '⏳ Saving...';

      try {
        const res = await fetch('/punch', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            status,
            latitude: userLat,
            longitude: userLng,
            locationName: locationName || 'Unknown',
            timestamp
          })
        });

        const data = await res.json();

        if (data.success) {
          if (status === 'Punch In') {
            document.getElementById('inTime').textContent = timeStr;
            btn.innerHTML = '<span class="btn-icon">✅</span> IN Recorded';
            attendanceState.canPunchIn = false;
            attendanceState.canPunchOut = true;
            attendanceState.inTimeLabel = timeStr;
            sessionLog[userEmail] = sessionLog[userEmail] || { date: now.toDateString(), inTime: null, outTime: null };
            sessionLog[userEmail].date = now.toDateString();
            sessionLog[userEmail].inTime = timeStr;
            document.getElementById('todayRecord').style.display = 'block';
          } else {
            document.getElementById('outTime').textContent = timeStr;
            btn.innerHTML = '<span class="btn-icon">✅</span> OUT Recorded';
            attendanceState.canPunchOut = false;
            attendanceState.outTimeLabel = timeStr;
            sessionLog[userEmail] = sessionLog[userEmail] || { date: now.toDateString(), inTime: null, outTime: null };
            sessionLog[userEmail].date = now.toDateString();
            sessionLog[userEmail].outTime = timeStr;
          }

          syncButtonState();
          sessionStorage.setItem('attendanceLog', JSON.stringify(sessionLog));
          showToast(`✅ ${status} at ${timeStr} — ${locationName}`);
        } else {
          btn.disabled = false;
          btn.innerHTML = status === 'Punch In'
            ? '<span class="btn-icon">🟢</span> Punch IN'
            : '<span class="btn-icon">🔴</span> Punch OUT';
          showMsg(data.message || 'Something went wrong', 'error');
        }
      } catch (err) {
        btn.disabled = false;
        showMsg('Network error. Check connection.', 'error');
      }
    }

    // ─── HELPERS ──────────────────────────────────────────────────────────────
    function setStatus(text, type) {
      const banner = document.getElementById('statusBanner');
      const statusText = document.getElementById('statusText');
      statusText.textContent = text;
      banner.className = 'status-banner ' + type;
    }

    function showMsg(text, type) {
      const box = document.getElementById('msgBox');
      box.textContent = text;
      box.className = 'msg ' + type;
      box.style.display = 'block';
      setTimeout(() => box.style.display = 'none', 4000);
    }

    function showToast(msg) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3500);
    }
  </script>
</body>
</html>
